# RocketRide Engine
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=MYAPIKEY

# Active LLM provider for diagnostics and connectivity checks: openai | anthropic
LLM_PROVIDER=openai

# LLM Provider (GMI Cloud / OpenAI-compatible)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.gmi-serving.com/v1
OPENAI_MODEL=openai/gpt-5.4
# Optional: allow diagnostics to continue when Layer 2 sees known external TLS-interception errors
ALLOW_LLM_DEGRADED=false

# Anthropic LLM (recommended fallback when GMI is blocked)
ROCKETRIDE_ANTHROPIC_KEY=your-anthropic-key
ROCKETRIDE_ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key

# Neo4j Aura
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=your-username
NEO4J_PASSWORD=your-password

# Apify (for seeding only)
APIFY_API_TOKEN=your-apify-token

# RocketRide pipeline env vars (used in .pipe file substitution)
ROCKETRIDE_OPENAI_KEY=your-openai-api-key
ROCKETRIDE_OPENAI_BASE_URL=https://api.gmi-serving.com/v1
ROCKETRIDE_OPENAI_MODEL=openai/gpt-5.4
ROCKETRIDE_PIPELINE_FILE=creator-discovery.pipe
ROCKETRIDE_NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
ROCKETRIDE_NEO4J_USER=your-username
ROCKETRIDE_NEO4J_PASSWORD=your-password
